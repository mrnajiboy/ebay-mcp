# eBay MCP Server Configuration

# Required: Your eBay app credentials
EBAY_CLIENT_ID=your-client-id
EBAY_CLIENT_SECRET=your-client-secret

# Your eBay RuName / Redirect URI name configured in the eBay Developer Portal
EBAY_REDIRECT_URI=your-ebay-runame
EBAY_ENVIRONMENT=production

# Optional: Render / hosted settings
PORT=3000
PUBLIC_BASE_URL=https://your-render-service.onrender.com
EBAY_TOKEN_STORE_PATH=/var/data/ebay-user-tokens.json
EBAY_TOKEN_PERSISTENCE_MODE=file-only

# Optional: Marketplace defaults
# EBAY_MARKETPLACE_ID=EBAY_US
# EBAY_CONTENT_LANGUAGE=en-US

# Optional: Existing user tokens (the hosted OAuth flow will store these automatically)
# EBAY_USER_REFRESH_TOKEN=your-refresh-token
# EBAY_USER_ACCESS_TOKEN=your-access-token
# EBAY_APP_ACCESS_TOKEN=your-app-access-token

# Logging Configuration
# EBAY_LOG_LEVEL=info
# EBAY_ENABLE_FILE_LOGGING=true

# Optional: Protect MCP endpoint itself with external bearer token auth.
# Leave disabled for a private single-user deployment unless you explicitly configure it.
# OAUTH_ENABLED=false
# OAUTH_AUTH_SERVER_URL=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_REQUIRED_SCOPES=mcp:tools
# OAUTH_USE_INTROSPECTION=true
